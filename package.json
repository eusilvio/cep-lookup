{
  "name": "@eusilvio/monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @eusilvio/cep-lookup && npm run build -w @eusilvio/cep-lookup-react && npm run build -w @eusilvio/cep-lookup-vue",
    "test": "npm run test --workspaces --if-present",
    "benchmark": "ts-node benchmarks/lookup.bench.ts --json benchmarks/history/latest.json",
    "benchmark:compare": "node benchmarks/compare-benchmark.mjs benchmarks/baseline.json benchmarks/history/latest.json 0.35",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "find-up": "^8.0.0",
    "pkg-dir": "^8.0.0",
    "tinybench": "^6.0.0",
    "typescript": "^5.9.2",
    "@changesets/cli": "^2.29.7"
  }
}
